<% layout("/layouts/boilerplate") %>

<style>
    #filters {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        align-items: center;
        padding: 1rem;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
    }

    #filters::-webkit-scrollbar {
        display: none;
    }

    .filter {
        flex: 0 0 auto;
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .filter p {
        font-size: 0.8rem;
    }

    .tax-info {
        display: none;
    }

    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 0.5rem;
        display: flex;
        align-items: center;
        flex: 0 0 auto;
    }

    /* Hide dropdown trigger on large screens */
    .mobile-dropdown {
        display: none;
    }

    @media (max-width: 768px) {
        .mobile-dropdown {
            display: block;
            margin: 1rem;
        }

        .desktop-nav {
            display: none;
        }
    }
</style>

    <body>
        <div class="container mt-3">
            <!-- <h3>All Listings</h3> -->
            <div id="filters">
                <div class="filter">
                    <div><i class="fa-solid fa-fire"></i></div>
                    <p>Trending</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p>Rooms</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-mountain-city"></i></div>
                    <p>Top Cities</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-mountain"></i></div>
                    <p>Mountains</p>
                </div>
                <div class="filter">
                    <div><i class="fa-brands fa-fort-awesome"></i></div>
                    <p>Castles</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-person-swimming"></i></div>
                    <p>Amazing Pools</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-campground"></i></div>
                    <p>Comping</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-money-bill-wheat"></i></div>
                    <p>Farms</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-snowflake"></i></div>
                    <p>Arctic</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-umbrella-beach"></i></div>
                    <p>Beach</p>
                </div>
                <div class="filter">
                    <div><i class="fa-solid fa-caravan"></i></div>
                    <p>Camper Vans</p>
                </div>
            
                <div class="tax-toggle">
                    <div class="form-check-reverse form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault" />
                        <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
                    </div>
                </div>
            </div>

            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-3">
                <% for (let listing of allListing) { %>
                    <div class="col">
                        <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                            <div class="card listing-card h-100">
                                <!-- Listing Image -->
                                <% if(listing.image && listing.image.url){ %>
                                    <img class="card-img-top" src="<%= listing.image.url %>" alt="Listing image"
                                        style="height: 18rem; object-fit: cover;">
                                    <% } else { %>
                                        <img class="card-img-top" src="/images/placeholder.jpg" alt="No image"
                                            style="height: 18rem; object-fit: cover;">
                                        <% } %>

                                            <div class="card-body">
                                                <!-- Title -->
                                                <h5 class="card-title">
                                                    <%= listing.title %>
                                                </h5>

                                                <!-- Price -->
                                                <p class="card-text">
                                                    <i class="fa fa-inr"></i>
                                                    <%= listing.price.toLocaleString("en-IN") %>/night
                                                    <i class="tax-info"> &nbsp; +18% GST</i>
                                                </p>

                                                <!-- Category Badge -->
                                                <% if(listing.category){ %>
                                                    <span class="badge bg-dark">
                                                        <%= listing.category %>
                                                    </span>
                                                    <% } %>
                                            </div>
                            </div>
                        </a>
                    </div>
                    <% } %>
            </div>
        </div>

        <script>
            let taxSwitch = document.getElementById("flexSwitchCheckDefault");
            taxSwitch.addEventListener("click", () => {
                let taxInfo = document.getElementsByClassName("tax-info");
                for (info of taxInfo) {
                    if (info.style.display != "inline") {
                        info.style.display = "inline";
                    } else {
                        info.style.display = "none";
                    }
                }
            });
        </script>
    </body>